---
const { quote, author } = Astro.props;
---

{quote && (
  <section class="section-quote py-20 px-4">
    <div class="container">
      <figure class="mx-auto max-w-4xl text-center">
        <blockquote class="text-xl md:text-2xl leading-relaxed italic tracking-wide text-primary-950">
          <span class="block">“{quote}”</span>
        </blockquote>
        {author && (
          <figcaption class="mt-10 text-xl md:text-2xl font-medium text-primary-600">
            {author}
          </figcaption>
        )}
      </figure>
    </div>
  </section>
)}
